{
  "manifest_version": 3,
  "name": "SuperBookmark",
  "version": "1.0",
  "description": "SuperBookmark - 点击扩展图标打开",
  "background": {
    "service_worker": "assets/background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "storage",
    "bookmarks",
    "tabs"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}