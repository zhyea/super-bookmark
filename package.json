{
  "name": "super-bookmark",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node scripts/sync-chrome-locales.mjs",
    "dev": "vite",
    "prebuild": "node scripts/sync-chrome-locales.mjs",
    "prebuild:firefox": "node scripts/sync-chrome-locales.mjs",
    "build": "vite build",
    "build:firefox": "vite build --outDir dist-firefox && node scripts/emit-firefox-manifest.mjs dist-firefox",
    "preview": "vite preview",
    "gen:engine-icons": "node scripts/export-engine-icons.mjs",
    "gen:icons": "node scripts/build-extension-icons.mjs",
    "gen:locales": "node scripts/sync-chrome-locales.mjs",
    "lint": "eslint src --ext .js,.vue",
    "lint:fix": "eslint src --ext .js,.vue --fix",
    "format": "prettier --write \"src/**/*.{js,vue,css}\""
  },
  "dependencies": {
    "vue": "^3.5.13",
    "vue-i18n": "^11.3.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@vitejs/plugin-vue": "^5.2.1",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.27.0",
    "prettier": "^3.3.3",
    "sharp": "^0.34.5",
    "typescript": "^5.5.4",
    "vite": "^6.0.7"
  }
}
