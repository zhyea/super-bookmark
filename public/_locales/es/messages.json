  "guideH1": {
    "message": "SuperBookmark · Guía",
    "description": "UI string: guideH1"
  },
  "guideIntro": {
    "message": "Cómo organizar marcadores y usar la extensión.",
    "description": "UI string: guideIntro"
  },
  "g1h": {
    "message": "1. Estructura de carpetas",
    "description": "UI string: g1h"
  },
  "g1p": {
    "message": "La extensión usa la <strong>jerarquía de carpetas</strong> de Chrome:",
    "description": "UI string: g1p"
  },
  "g1li1": {
    "message": "<strong>Primer nivel</strong>: estructura superior de Chrome; categorías principales aquí. Con <strong>varias raíces</strong>, cámbialas en la <strong>primera fila superior</strong>; con una sola, esa fila no se muestra.",
    "description": "UI string: g1li1"
  },
  "g1li2": {
    "message": "<strong>Segundo nivel</strong>: la <strong>segunda fila superior</strong> son subcategorías; si no hay, solo el nombre del primer nivel.",
    "description": "UI string: g1li2"
  },
  "g1li3": {
    "message": "<strong>Tercer nivel o más</strong>: los nombres son <strong>etiquetas</strong> en las tarjetas.",
    "description": "UI string: g1li3"
  },
  "g1note": {
    "message": "Si la lista está vacía, cree carpetas en la barra de marcadores.",
    "description": "UI string: g1note"
  },
  "g2h": {
    "message": "2. Navegar y buscar",
    "description": "UI string: g2h"
  },
  "g2li1": {
    "message": "Con varias categorías principales, use la primera fila superior y luego la segunda. Con una sola, basta la segunda. Con carpetas de tercer nivel, aparece un submenú a la izquierda.",
    "description": "UI string: g2li1"
  },
  "g2li2": {
    "message": "La <strong>barra de etiquetas</strong> filtra la vista (incl. «Todos»). Flechas para desplazar.",
    "description": "UI string: g2li2"
  },
  "g2li3": {
    "message": "Búsqueda por título, URL y etiquetas.",
    "description": "UI string: g2li3"
  },
  "g3h": {
    "message": "3. Modo edición",
    "description": "UI string: g3h"
  },
  "g3p": {
    "message": "Active el <strong>modo edición</strong> en ⚙ Ajustes:",
    "description": "UI string: g3p"
  },
  "g3li1": {
    "message": "<strong>✏️ Editar</strong>: título, carpeta, etiquetas (máx. 3, 16 caracteres).",
    "description": "UI string: g3li1"
  },
  "g3li2": {
    "message": "<strong>🗑 Eliminar</strong>: quita el marcador de Chrome.",
    "description": "UI string: g3li2"
  },
  "g3li3": {
    "message": "<strong>Clic derecho</strong> para el menú contextual.",
    "description": "UI string: g3li3"
  },
  "g4h": {
    "message": "4. Arrastrar",
    "description": "UI string: g4h"
  },
  "g4p": {
    "message": "Arrastre tarjetas a la fila principal superior (si hay varias raíces), a subcategorías o a subcarpetas izquierdas. Reordene en la misma lista.",
    "description": "UI string: g4p"
  },
  "g5h": {
    "message": "5. Ajustes",
    "description": "UI string: g5h"
  },
  "g5li1": {
    "message": "<strong>Modo edición</strong>: mostrar editar, eliminar y arrastrar.",
    "description": "UI string: g5li1"
  },
  "g5li2": {
    "message": "<strong>Columnas</strong>: 3 / 4 / 5.",
    "description": "UI string: g5li2"
  },
  "g5li3": {
    "message": "<strong>Ancho</strong>: 50%–100% del ancho de la ventana (mín. 400px), ajustable con el control deslizante.",
    "description": "UI string: g5li3"
  },
  "g5li4": {
    "message": "<strong>Colores / imagen</strong>: fondo; imágenes pequeñas recomendadas.",
    "description": "UI string: g5li4"
  },
  "g5li5": {
    "message": "<strong>Pestaña nueva</strong>: abre esta página al crear pestaña.",
    "description": "UI string: g5li5"
  },
  "g5li6": {
    "message": "<strong>Idioma</strong>: varios idiomas disponibles.",
    "description": "UI string: g5li6"
  },
