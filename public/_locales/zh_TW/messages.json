  "guideH1": {
    "message": "超級書籤 SuperBookmark · 使用說明",
    "description": "UI string: guideH1"
  },
  "guideIntro": {
    "message": "本頁說明如何從瀏覽器書籤列組織內容，以及擴充功能內的操作方式。",
    "description": "UI string: guideIntro"
  },
  "g1h": {
    "message": "一、書籤目錄怎麼建",
    "description": "UI string: g1h"
  },
  "g1p": {
    "message": "擴充功能會依瀏覽器書籤列（例如 Firefox 書籤工具列 / 其他書籤）的<strong>資料夾層級</strong>自動歸類：",
    "description": "UI string: g1p"
  },
  "g1li1": {
    "message": "<strong>一級資料夾</strong>：瀏覽器書籤的頂層結構，在擴充功能中作為主分類；<strong>有多個頂層書籤根</strong>時可在<strong>頁頂第一行</strong>切換，僅有一個根時不顯示該行。",
    "description": "UI string: g1li1"
  },
  "g1li2": {
    "message": "<strong>二級資料夾</strong>：選定主分類後，<strong>頁頂第二行</strong>橫向為子分類；若該主分類下沒有二級資料夾，則會以一級名稱作為唯一子類。",
    "description": "UI string: g1li2"
  },
  "g1li3": {
    "message": "<strong>三級及以下資料夾</strong>：其名稱會作為該書籤的<strong>標籤</strong>顯示在卡片上，便於篩選。",
    "description": "UI string: g1li3"
  },
  "g1note": {
    "message": "若列表為空，請先在瀏覽器書籤列中建立上述資料夾並新增網址書籤。",
    "description": "UI string: g1note"
  },
  "g2h": {
    "message": "二、瀏覽與搜尋",
    "description": "UI string: g2h"
  },
  "g2li1": {
    "message": "多個主分類時先點頁頂第一行切換；再點其下第二行切換子分類。僅一個主分類時只需用第二行。有三級資料夾時左側會出現子夾選單。",
    "description": "UI string: g2li1"
  },
  "g2li2": {
    "message": "內容區上方的<strong>標籤列</strong>可篩選目前分類下的書籤（含「全部」）。標籤較多時可點左右箭頭橫向捲動。",
    "description": "UI string: g2li2"
  },
  "g2li3": {
    "message": "頂部搜尋框可依標題、網址及標籤關鍵字篩選目前檢視中的書籤。",
    "description": "UI string: g2li3"
  },
  "g3h": {
    "message": "三、編輯模式（維護按鈕）",
    "description": "UI string: g3h"
  },
  "g3p": {
    "message": "在右下角 <strong>⚙ 設定</strong> 中開啟「編輯模式」後，每張卡片會顯示維護按鈕：",
    "description": "UI string: g3p"
  },
  "g3li1": {
    "message": "<strong>✏️ 編輯</strong>：修改標題、書籤所在資料夾（分類）、自訂標籤（最多 3 個，每標籤最多 16 字）。標籤可用 Enter、空白、Tab 或中英文逗號分隔輸入。",
    "description": "UI string: g3li1"
  },
  "g3li2": {
    "message": "<strong>🗑 刪除</strong>：從瀏覽器書籤中移除此書籤。",
    "description": "UI string: g3li2"
  },
  "g3li3": {
    "message": "在卡片上<strong>右鍵</strong>可開啟快捷選單（編輯、刪除等）。",
    "description": "UI string: g3li3"
  },
  "g4h": {
    "message": "四、拖曳移動書籤",
    "description": "UI string: g4h"
  },
  "g4p": {
    "message": "開啟編輯模式後，可將卡片<strong>拖到</strong>頁頂主分類（多個根時第一行）、頂部子分類或左側子資料夾上，書籤會移動到對應資料夾（與瀏覽器書籤結構同步）。在同一清單內也可拖曳調整排序。",
    "description": "UI string: g4p"
  },
  "g5h": {
    "message": "五、設定項說明",
    "description": "UI string: g5h"
  },
  "g5li1": {
