  "guidePageTitle": {
    "message": "使用说明",
    "description": "UI string: guidePageTitle"
  },
  "guideH1": {
    "message": "超级书签 SuperBookmark · 使用说明",
    "description": "UI string: guideH1"
  },
  "guideIntro": {
    "message": "本页说明如何从浏览器书签栏组织内容，以及扩展内的操作方式。",
    "description": "UI string: guideIntro"
  },
  "g1h": {
    "message": "一、书签目录怎么建",
    "description": "UI string: g1h"
  },
  "g1p": {
    "message": "扩展会按 Chrome 书签栏的<strong>文件夹层级</strong>自动归类：",
    "description": "UI string: g1p"
  },
  "g1li1": {
    "message": "<strong>一级文件夹</strong>：Chrome 书签的顶层结构，在扩展中作为主分类；<strong>存在多个顶层书签根</strong>时可在<strong>页顶第一行</strong>切换，仅有一个根时不显示该行。",
    "description": "UI string: g1li1"
  },
  "g1li2": {
    "message": "<strong>二级文件夹</strong>：选中主分类后，<strong>页顶第二行</strong>横向为子分类；若该主分类下没有二级文件夹，则会用一级名称作为唯一子类。",
    "description": "UI string: g1li2"
  },
  "g1li3": {
    "message": "<strong>三级及以下文件夹</strong>：其名称会作为该书签的<strong>标签</strong>显示在卡片上，便于筛选。",
    "description": "UI string: g1li3"
  },
  "g1note": {
    "message": "若列表为空，请先在 Chrome 书签栏中创建上述文件夹并添加网址书签。",
    "description": "UI string: g1note"
  },
  "g2h": {
    "message": "二、浏览与搜索",
    "description": "UI string: g2h"
  },
  "g2li1": {
    "message": "多个主分类时先点页顶第一行切换；再点其下第二行切换子分类。仅一个主分类时直接用第二行。有三级文件夹时左侧会出现子夹菜单。",
    "description": "UI string: g2li1"
  },
  "g2li2": {
    "message": "内容区上方的<strong>标签条</strong>可筛选当前分类下的书签（含「全部」）。标签较多时可点左右箭头横向滚动。",
    "description": "UI string: g2li2"
  },
  "g2li3": {
    "message": "顶部搜索框可按标题、网址及标签关键字过滤当前视图中的书签。",
    "description": "UI string: g2li3"
  },
  "g3h": {
    "message": "三、编辑模式（维护按钮）",
    "description": "UI string: g3h"
  },
  "g3p": {
    "message": "在右下角 <strong>⚙ 设置</strong> 中打开「编辑模式」后，每张卡片会显示维护按钮：",
    "description": "UI string: g3p"
  },
  "g3li1": {
    "message": "<strong>✏️ 编辑</strong>：修改标题、书签所在文件夹（分类）、自定义标签（最多 3 个，每标签最多 16 字）。标签可用回车、空格、Tab 或中英文逗号分隔输入。",
    "description": "UI string: g3li1"
  },
  "g3li2": {
    "message": "<strong>🗑 删除</strong>：从浏览器书签中移除该书签。",
    "description": "UI string: g3li2"
  },
  "g3li3": {
    "message": "在卡片上<strong>右键</strong>可打开快捷菜单（编辑、删除等）。",
    "description": "UI string: g3li3"
  },
  "g4h": {
    "message": "四、拖拽移动书签",
    "description": "UI string: g4h"
  },
  "g4p": {
    "message": "开启编辑模式后，可将卡片<strong>拖到</strong>页顶主分类（多个根时第一行）、顶部子分类或左侧子文件夹上，书签会移动到对应文件夹（与 Chrome 书签结构同步）。在同一列表内也可拖拽调整排序。",
    "description": "UI string: g4p"
  },
  "g5h": {
    "message": "五、设置项说明",
    "description": "UI string: g5h"
  },
  "g5li1": {
    "message": "<strong>编辑模式</strong>：开/关卡片上的编辑、删除与拖拽。",
    "description": "UI string: g5li1"
  },
  "g5li2": {
    "message": "<strong>卡片列数</strong>：3 / 4 / 5 列（实际列数会随窗口宽度自适应）。",
    "description": "UI string: g5li2"
  },
  "g5li3": {
    "message": "<strong>内容宽度</strong>：主区域相对视口宽度的 50%～100%（且不小于 400px），可用滑块调节。",
    "description": "UI string: g5li3"
  },
  "g5li4": {
    "message": "<strong>背景色 / 自选色 / 背景图</strong>：页面背景；背景图建议较小图片以节省扩展存储。",
    "description": "UI string: g5li4"
  },
  "g5li5": {
    "message": "<strong>替换默认新标签页</strong>：开启后，新建标签页将打开本书签页（需在扩展中开启对应选项后生效）。",
    "description": "UI string: g5li5"
  },
  "g5li6": {
    "message": "<strong>界面语言</strong>：简体中文、繁體中文、英文、西班牙语、德语、法语、日语、韩语。",
    "description": "UI string: g5li6"
  },
  "guideFoot": {
    "message": "SuperBookmark · 返回扩展主界面请打开新标签页或点击扩展图标",
    "description": "UI string: guideFoot"
  },
