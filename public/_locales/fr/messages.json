  "g1h": {
    "message": "1. Structure des dossiers",
    "description": "UI string: g1h"
  },
  "g1p": {
    "message": "L’extension suit la <strong>hiérarchie des dossiers</strong> Chrome :",
    "description": "UI string: g1p"
  },
  "g1li1": {
    "message": "<strong>Premier niveau</strong> : structure supérieure Chrome ; catégories principales. <strong>Plusieurs racines</strong> : première ligne d’en-tête ; une seule : cette ligne est masquée.",
    "description": "UI string: g1li1"
  },
  "g1li2": {
    "message": "<strong>Deuxième niveau</strong> : la <strong>deuxième ligne</strong> du haut pour les sous-catégories ; sinon seul le nom du premier niveau.",
    "description": "UI string: g1li2"
  },
  "g1li3": {
    "message": "<strong>Troisième niveau et plus</strong> : les noms deviennent des <strong>étiquettes de filtre</strong> dans la barre du haut, pas sur les cartes.",
    "description": "UI string: g1li3"
  },
  "g1note": {
    "message": "Si la liste est vide, créez des dossiers dans la barre de favoris.",
    "description": "UI string: g1note"
  },
  "g2h": {
    "message": "2. Parcourir et rechercher",
    "description": "UI string: g2h"
  },
  "g2li1": {
    "message": "Plusieurs catégories principales : d’abord la première ligne du haut, puis la deuxième. Une seule : seule la deuxième ligne. Troisième niveau : sous-menu à gauche.",
    "description": "UI string: g2li1"
  },
  "g2li2": {
    "message": "La <strong>barre d’étiquettes</strong> filtre la vue. Flèches pour défiler.",
    "description": "UI string: g2li2"
  },
  "g2li3": {
    "message": "Recherche par titre, URL et étiquettes.",
    "description": "UI string: g2li3"
  },
  "g3h": {
    "message": "3. Mode édition",
    "description": "UI string: g3h"
  },
  "g3p": {
    "message": "Activez le <strong>mode édition</strong> dans ⚙ Paramètres :",
    "description": "UI string: g3p"
  },
  "g3li1": {
    "message": "<strong>✏️ Modifier</strong> : titre, dossier, étiquettes (max 3, 16 car.).",
    "description": "UI string: g3li1"
  },
  "g3li2": {
    "message": "<strong>🗑 Supprimer</strong> : retire le favori de Chrome.",
    "description": "UI string: g3li2"
  },
  "g3li3": {
    "message": "<strong>Clic droit</strong> pour le menu contextuel.",
    "description": "UI string: g3li3"
  },
  "g4h": {
    "message": "4. Glisser-déposer",
    "description": "UI string: g4h"
  },
  "g4p": {
    "message": "Glissez les cartes vers la ligne principale du haut (si plusieurs racines), les sous-catégories ou les sous-dossiers à gauche. Réordonnez dans la même liste.",
    "description": "UI string: g4p"
  },
