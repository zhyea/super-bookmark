  "g1h": {
    "message": "1. Ordnerstruktur",
    "description": "UI string: g1h"
  },
  "g1p": {
    "message": "Die Erweiterung nutzt die <strong>Ordnerhierarchie</strong> von Chrome:",
    "description": "UI string: g1p"
  },
  "g1li1": {
    "message": "<strong>Oberste Ebene</strong>: Chromes oberste Lesezeichenstruktur; Hauptkategorien. Bei <strong>mehreren Wurzeln</strong> in der <strong>ersten Kopfzeile</strong> wechseln; bei nur einer wird sie ausgeblendet.",
    "description": "UI string: g1li1"
  },
  "g1li2": {
    "message": "<strong>Zweite Ebene</strong>: die <strong>zweite Kopfzeile</strong> mit Unterkategorien; fehlen sie, nur der Hauptname.",
    "description": "UI string: g1li2"
  },
  "g1li3": {
    "message": "<strong>Ab dritter Ebene</strong>: Ordnernamen werden zu <strong>Tags</strong> auf den Karten.",
    "description": "UI string: g1li3"
  },
  "g1note": {
    "message": "Bei leerer Liste Ordner in der Lesezeichenleiste anlegen.",
    "description": "UI string: g1note"
  },
  "g2h": {
    "message": "2. Navigation und Suche",
    "description": "UI string: g2h"
  },
  "g2li1": {
    "message": "Mehrere Hauptkategorien: zuerst erste Kopfzeile, dann zweite. Eine Hauptkategorie: nur zweite Zeile. Dritte Ebene: Untermenü links.",
    "description": "UI string: g2li1"
  },
  "g2li2": {
    "message": "<strong>Tag-Leiste</strong> filtert die Ansicht. Pfeile zum Scrollen.",
    "description": "UI string: g2li2"
  },
  "g2li3": {
    "message": "Suche nach Titel, URL und Tags.",
    "description": "UI string: g2li3"
  },
  "g3h": {
    "message": "3. Bearbeitungsmodus",
    "description": "UI string: g3h"
  },
  "g3p": {
    "message": "<strong>Bearbeitungsmodus</strong> unter ⚙ aktivieren:",
    "description": "UI string: g3p"
  },
  "g3li1": {
    "message": "<strong>✏️ Bearbeiten</strong>: Titel, Ordner, Tags (max. 3, 16 Zeichen).",
    "description": "UI string: g3li1"
  },
  "g3li2": {
    "message": "<strong>🗑 Löschen</strong>: Lesezeichen in Chrome entfernen.",
    "description": "UI string: g3li2"
  },
  "g3li3": {
    "message": "<strong>Rechtsklick</strong> für Kontextmenü.",
    "description": "UI string: g3li3"
  },
  "g4h": {
    "message": "4. Ziehen und Ablegen",
    "description": "UI string: g4h"
  },
  "g4p": {
    "message": "Karten auf die obere Hauptzeile (bei mehreren Wurzeln), Unterkategorien oder linke Unterordner ziehen. Sortierung in derselben Liste.",
    "description": "UI string: g4p"
  },
