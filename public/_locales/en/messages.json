  "guideH1": {
    "message": "SuperBookmark · User guide",
    "description": "UI string: guideH1"
  },
  "guideIntro": {
    "message": "How to organize bookmarks in the bar and use this extension.",
    "description": "UI string: guideIntro"
  },
  "g1h": {
    "message": "1. Folder structure",
    "description": "UI string: g1h"
  },
  "g1p": {
    "message": "The extension maps Edge’s <strong>bookmark folder hierarchy</strong>:",
    "description": "UI string: g1p"
  },
  "g1li1": {
    "message": "<strong>Top-level folders</strong>: Edge’s top bookmark structure; in the extension they are <strong>main categories</strong>. If there are <strong>several roots</strong>, switch them on the <strong>first header row</strong>; with a single root that row is hidden.",
    "description": "UI string: g1li1"
  },
  "g1li2": {
    "message": "<strong>Second-level folders</strong>: after choosing a main category, the <strong>second header row</strong> lists subcategories; if there are none, the top-level name is the only subcategory.",
    "description": "UI string: g1li2"
  },
  "g1li3": {
    "message": "<strong>Third level and below</strong>: folder names become <strong>tags</strong> on cards for filtering.",
    "description": "UI string: g1li3"
  },
  "g1note": {
    "message": "If the list is empty, create folders in the Edge favorites bar and add bookmarks.",
    "description": "UI string: g1note"
  },
  "g2h": {
    "message": "2. Browse and search",
    "description": "UI string: g2h"
  },
  "g2li1": {
    "message": "With several main categories, use the first header row, then the second row for subcategories. With one main category, only the second row is needed. When there are third-level folders, a submenu appears on the left.",
    "description": "UI string: g2li1"
  },
  "g2li2": {
    "message": "The <strong>tag bar</strong> filters bookmarks in the current view (including “All”). Use the arrows to scroll when there are many tags.",
    "description": "UI string: g2li2"
  },
  "g2li3": {
    "message": "The search box filters by title, URL and tag keywords.",
    "description": "UI string: g2li3"
  },
  "g3h": {
    "message": "3. Edit mode",
    "description": "UI string: g3h"
  },
  "g3p": {
    "message": "Turn on <strong>Edit mode</strong> in ⚙ Settings to show actions on each card:",
    "description": "UI string: g3p"
  },
  "g3li1": {
    "message": "<strong>✏️ Edit</strong>: title, folder, custom tags (max 3, 16 chars). Separate tags with Enter, Space, Tab or commas.",
    "description": "UI string: g3li1"
  },
  "g3li2": {
    "message": "<strong>🗑 Delete</strong>: removes the bookmark from Edge.",
    "description": "UI string: g3li2"
  },
  "g3li3": {
    "message": "<strong>Right-click</strong> a card for the context menu.",
    "description": "UI string: g3li3"
  },
  "g4h": {
    "message": "4. Drag and drop",
    "description": "UI string: g4h"
  },
  "g4p": {
    "message": "With edit mode on, drag cards onto the top main row (when multiple roots), top subcategories, or left subfolders to move bookmarks. Reorder within the same list by dragging.",
    "description": "UI string: g4p"
  },
  "g5h": {
    "message": "5. Settings",
    "description": "UI string: g5h"
  },
  "g5li1": {
    "message": "<strong>Edit mode</strong>: show or hide edit, delete and drag.",
    "description": "UI string: g5li1"
  },
  "g5li2": {
    "message": "<strong>Columns</strong>: 3 / 4 / 5 (adapts to window width).",
    "description": "UI string: g5li2"
  },
  "g5li3": {
    "message": "<strong>Content width</strong>: 50%–100% of the viewport (min. 400px), adjustable with the slider.",
    "description": "UI string: g5li3"
  },
  "g5li4": {
    "message": "<strong>Colors / custom / image</strong>: page background; prefer small images for storage.",
    "description": "UI string: g5li4"
  },
  "g5li5": {
    "message": "<strong>Replace new tab</strong>: new tabs open this page when enabled in the extension.",
    "description": "UI string: g5li5"
  },
  "g5li6": {
    "message": "<strong>Language</strong>: Simplified & Traditional Chinese, English, Spanish, German, French, Japanese, Korean.",
    "description": "UI string: g5li6"
  },
  "guideFoot": {
    "message": "SuperBookmark · Open a new tab or the extension icon to return",
    "description": "UI string: guideFoot"
  },
