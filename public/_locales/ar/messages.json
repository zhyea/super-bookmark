  "g1p": {
    "message": "تعتمد الإضافة على <strong>هيكل مجلدات</strong> الإشارات المرجعية في Chrome:",
    "description": "UI string: g1p"
  },
  "g1li1": {
    "message": "<strong>المستوى الأول</strong>: البنية العليا في Chrome؛ التصنيفات الرئيسية. عند <strong>وجود عدة جذور</strong> استخدم <strong>الصف الأول في الأعلى</strong>؛ عند جذر واحد يُخفى هذا الصف.",
    "description": "UI string: g1li1"
  },
  "g1li2": {
    "message": "<strong>المستوى الثاني</strong>: <strong>الصف الثاني في الأعلى</strong> للتصنيفات الفرعية؛ وإن لم توجد، يُستخدم اسم المستوى الأول فقط.",
    "description": "UI string: g1li2"
  },
  "g1li3": {
    "message": "<strong>المستوى الثالث وما بعده</strong>: تُستخدم أسماء المجلدات كـ <strong>وسوم تصفية</strong> في الشريط العلوي، وليس كوسوم على البطاقات.",
    "description": "UI string: g1li3"
  },
  "g1note": {
    "message": "إذا كانت القائمة فارغة، أنشئ مجلدات في شريط الإشارات المرجعية ثم أضف الروابط.",
    "description": "UI string: g1note"
  },
  "g2h": {
    "message": "2. التصفح والبحث",
    "description": "UI string: g2h"
  },
