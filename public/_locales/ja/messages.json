  "guideH1": {
    "message": "SuperBookmark · 使い方",
    "description": "UI string: guideH1"
  },
  "guideIntro": {
    "message": "ブックマークバーの整理方法と拡張機能の操作です。",
    "description": "UI string: guideIntro"
  },
  "g1h": {
    "message": "1. フォルダの作り方",
    "description": "UI string: g1h"
  },
  "g1p": {
    "message": "Chrome の<strong>フォルダ階層</strong>に対応します。",
    "description": "UI string: g1p"
  },
  "g1li1": {
    "message": "<strong>第1階層</strong>：Chrome の最上位構造・大分類。<strong>複数のルート</strong>があるときは<strong>ヘッダー1行目</strong>で切替。1つだけならその行は非表示。",
    "description": "UI string: g1li1"
  },
  "g1li2": {
    "message": "<strong>第2階層</strong>：<strong>ヘッダー2行目</strong>のサブ分類。ない場合は第1階層名のみ。",
    "description": "UI string: g1li2"
  },
  "g1li3": {
    "message": "<strong>第3階層以下</strong>：フォルダ名がカードの<strong>タグ</strong>になります。",
    "description": "UI string: g1li3"
  },
  "g1note": {
    "message": "一覧が空のときは、ブックマークバーにフォルダとブックマークを追加してください。",
    "description": "UI string: g1note"
  },
  "g2h": {
    "message": "2. 閲覧と検索",
    "description": "UI string: g2h"
  },
  "g2li1": {
    "message": "大分類が複数のときは上段1行目→その下の2行目。1つのときは2行目だけ。第3階層があると左にサブメニュー。",
    "description": "UI string: g2li1"
  },
  "g2li2": {
    "message": "<strong>タグバー</strong>で絞り込み（「すべて」含む）。矢印で横スクロール。",
    "description": "UI string: g2li2"
  },
  "g2li3": {
    "message": "検索でタイトル・URL・タグを絞り込み。",
    "description": "UI string: g2li3"
  },
  "g3h": {
    "message": "3. 編集モード",
    "description": "UI string: g3h"
  },
  "g3p": {
    "message": "右下 ⚙ <strong>設定</strong>で編集モードをオンにすると、各カードにボタンが表示されます。",
    "description": "UI string: g3p"
  },
  "g3li1": {
    "message": "<strong>✏️ 編集</strong>：タイトル・フォルダ・タグ（最大3、各16文字）。",
    "description": "UI string: g3li1"
  },
  "g3li2": {
    "message": "<strong>🗑 削除</strong>：Chrome からブックマークを削除。",
    "description": "UI string: g3li2"
  },
  "g3li3": {
    "message": "<strong>右クリック</strong>でコンテキストメニュー。",
    "description": "UI string: g3li3"
  },
  "g4h": {
    "message": "4. ドラッグで移動",
    "description": "UI string: g4h"
  },
  "g4p": {
    "message": "カードをヘッダー上段（複数ルート時）、サブ分類、または左のサブフォルダへドラッグして移動。同じ一覧内で並べ替え可。",
    "description": "UI string: g4p"
  },
  "g5h": {
    "message": "5. 設定",
    "description": "UI string: g5h"
  },
  "g5li1": {
    "message": "<strong>編集モード</strong>：編集・削除・ドラッグの表示。",
    "description": "UI string: g5li1"
  },
  "g5li2": {
    "message": "<strong>列数</strong>：3 / 4 / 5（幅に応じて調整）。",
    "description": "UI string: g5li2"
  },
  "g5li3": {
    "message": "<strong>コンテンツ幅</strong>：ビューポート幅の 50%～100%（最小 400px）、スライダーで調整。",
    "description": "UI string: g5li3"
  },
  "g5li4": {
    "message": "<strong>背景色・画像</strong>：ページ背景。画像は小さめ推奨。",
    "description": "UI string: g5li4"
  },
  "g5li5": {
    "message": "<strong>新しいタブ</strong>：オンでこのページを開きます。",
