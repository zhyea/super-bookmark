  "guideH1": {
    "message": "SuperBookmark · Guida",
    "description": "UI string: guideH1"
  },
  "guideIntro": {
    "message": "Come organizzare i segnalibri nella barra e usare questa estensione.",
    "description": "UI string: guideIntro"
  },
  "g1h": {
    "message": "1. Struttura cartelle",
    "description": "UI string: g1h"
  },
  "g1p": {
    "message": "L’estensione usa la <strong>gerarchia cartelle</strong> dei segnalibri di Edge:",
    "description": "UI string: g1p"
  },
  "g1li1": {
    "message": "<strong>Primo livello</strong>: struttura superiore di Edge; categorie principali. Con <strong>più radici</strong>, usa la <strong>prima riga in alto</strong>; con una sola, quella riga non compare.",
    "description": "UI string: g1li1"
  },
  "g1li2": {
    "message": "<strong>Secondo livello</strong>: la <strong>seconda riga in alto</strong> per le sottocategorie; se assenti, solo il nome del primo livello.",
    "description": "UI string: g1li2"
  },
  "g1li3": {
    "message": "<strong>Terzo livello e oltre</strong>: i nomi cartella diventano <strong>tag filtro</strong> nella barra in alto, non tag sulle card.",
    "description": "UI string: g1li3"
  },
  "g1note": {
    "message": "Se la lista è vuota, crea cartelle nella barra dei segnalibri di Edge e aggiungi segnalibri.",
    "description": "UI string: g1note"
  },
  "g2h": {
    "message": "2. Navigazione e ricerca",
    "description": "UI string: g2h"
  },
  "g2li1": {
    "message": "Più categorie principali: prima riga in alto, poi la seconda. Una sola: solo la seconda. Terzo livello: sottomenu a sinistra.",
    "description": "UI string: g2li1"
  },
  "g2li2": {
    "message": "La <strong>barra tag</strong> filtra i segnalibri nella vista corrente (incluso “Tutti”). Usa le frecce per scorrere orizzontalmente.",
    "description": "UI string: g2li2"
  },
  "g2li3": {
    "message": "La casella di ricerca filtra per titolo, URL e tag.",
    "description": "UI string: g2li3"
  },
  "g3h": {
    "message": "3. Modalità modifica",
    "description": "UI string: g3h"
  },
  "g3p": {
    "message": "Attiva la <strong>modalità modifica</strong> da ☰ Impostazioni in alto a destra per mostrare azioni su ogni card:",
    "description": "UI string: g3p"
  },
  "g3li1": {
    "message": "<strong>✏️ Modifica</strong>: titolo, cartella, tag personalizzati (max 3, 16 caratteri).",
    "description": "UI string: g3li1"
  },
  "g3li2": {
    "message": "<strong>🗑 Elimina</strong>: rimuove il segnalibro da Edge.",
    "description": "UI string: g3li2"
  },
  "g3li3": {
    "message": "<strong>Clic destro</strong> su una card per il menu contestuale.",
    "description": "UI string: g3li3"
  },
  "g4h": {
    "message": "4. Trascina e rilascia",
    "description": "UI string: g4h"
  },
  "g4p": {
    "message": "Con modalità modifica, trascina le card sulla riga principale in alto (se più radici), sulle sottocategorie o sulle sottocartelle a sinistra. Riordina nella stessa lista.",
    "description": "UI string: g4p"
  },
  "g5h": {
    "message": "5. Impostazioni",
    "description": "UI string: g5h"
  },
  "g5li1": {
    "message": "<strong>Modalità modifica</strong>: mostra/nasconde modifica, elimina e trascina.",
    "description": "UI string: g5li1"
  },
  "g5li2": {
    "message": "<strong>Colonne</strong>: 3 / 4 / 5 (adattate alla larghezza finestra).",
    "description": "UI string: g5li2"
  },
  "g5li3": {
    "message": "<strong>Larghezza contenuto</strong>: 50%–100% della larghezza finestra (min. 400px), regolabile con il cursore.",
    "description": "UI string: g5li3"
  },
  "g5li4": {
    "message": "<strong>Colori / personalizzato / immagine</strong>: sfondo pagina; preferisci immagini piccole per risparmiare spazio.",
    "description": "UI string: g5li4"
  },
  "g5li5": {
    "message": "<strong>Sostituisci nuova scheda</strong>: se attivo, le nuove schede aprono questa pagina.",
    "description": "UI string: g5li5"
  },
  "g5li6": {
    "message": "<strong>Lingua</strong>: seleziona la lingua dell’interfaccia.",
    "description": "UI string: g5li6"
  },
  "guideFoot": {
    "message": "SuperBookmark · Apri una nuova scheda o l’icona estensione per tornare",
    "description": "UI string: guideFoot"
  },
