{
  "manifest_version": 3,
  "default_locale": "zh_CN",
  "name": "__MSG_extName__",
  "version": "1.0.9",
  "description": "__MSG_extDescription__",
  "background": {
    "service_worker": "assets/background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "storage",
    "bookmarks",
    "tabs"
  ],
  "host_permissions": [
    "https://www.bing.com/*",
    "https://picsum.photos/*",
    "https://api.pexels.com/*",
    "https://images.pexels.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}