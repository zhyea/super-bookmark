{
  "manifest_version": 3,
  "default_locale": "zh_CN",
  "name": "__MSG_extName__",
  "version": "1.0.8",
  "description": "__MSG_extDescription__",
  "background": {
    "service_worker": "assets/background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
